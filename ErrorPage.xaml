<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IdpDemo.ErrorPage"
             Title="Configuration Error"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">

    <Grid Padding="32">
        <Border MaximumWidthRequest="560"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 24"
                Padding="32">
            <VerticalStackLayout Spacing="18">
                <Label Text="Application configuration is invalid"
                       FontFamily="OpenSansSemibold"
                       FontSize="28"
                       SemanticProperties.HeadingLevel="Level1"
                       TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}" />

                <Label Text="The application cannot start because its embedded configuration is missing or malformed. The detailed error was written to the console."
                       FontSize="16"
                       LineHeight="1.4"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}" />

                <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        StrokeShape="RoundRectangle 16"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#111827}">
                    <Label x:Name="ErrorMessageLabel"
                           FontSize="14"
                           LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}" />
                </Border>

                <Button Text="Close Application"
                        Clicked="OnCloseClicked"
                        HorizontalOptions="Fill" />
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
